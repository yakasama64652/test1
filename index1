<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>VA Classroom Dashboard</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f6f9;
}

.topbar {
    background: #1abc9c;
    color: white;
    padding: 15px;
}

.container {
    display: flex;
    height: calc(100vh - 60px);
}

.sidebar {
    width: 25%;
    background: #2c3e50;
    color: white;
    padding: 20px;
}

.sidebar button {
    width: 100%;
    margin: 5px 0;
    padding: 10px;
    background: #34495e;
    border: none;
    color: white;
    cursor: pointer;
}

.main {
    width: 75%;
    padding: 20px;
    overflow-y: auto;
}

.card {
    background: white;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 15px;
}

input, select, button {
    padding: 10px;
    margin: 8px 0;
    width: 280px;
}

button {
    background: #1abc9c;
    border: none;
    color: white;
    cursor: pointer;
}

.grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
}

.seat {
    background: #ecf0f1;
    border-radius: 8px;
    padding: 10px;
    text-align: center;
    cursor: pointer;
    min-height: 70px;
    transition: 0.2s;
}

.seat.highlight {
    border: 3px solid #1abc9c;
    transform: scale(1.05);
}

/* TOAST */
.toast {
    position: fixed;
    top: 20px;
    right: 20px;
    background: white;
    color: #2c3e50;
    padding: 14px;
    border-left: 5px solid #1abc9c;
    border-radius: 10px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    opacity: 0;
    transform: translateX(100px);
    transition: 0.3s;
    z-index: 9999;
}

.toast.show {
    opacity: 1;
    transform: translateX(0);
}

/* MODALS */
.modal-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;

    opacity: 0;
    pointer-events: none;
    transition: 0.25s ease;
}

.modal-overlay.show {
    opacity: 1;
    pointer-events: auto;
}

.hidden { display: none; }

.modal-box, .action-box {
    background: white;
    width: 340px;
    border-radius: 12px;
    text-align: center;
    padding: 20px;
    transform: translateY(20px) scale(0.95);
    opacity: 0;
    transition: 0.25s ease;
}

.modal-overlay.show .modal-box,
.modal-overlay.show .action-box {
    transform: translateY(0) scale(1);
    opacity: 1;
}

.modal-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 15px;
}

.modal-actions button {
    width: 45%;
}

#modalCancel { background: #ccc; }
#modalOk { background: #1abc9c; color: white; }

/* ACTION */
.action-box {
    width: 280px;
}

.action-box button {
    width: 100%;
    margin: 6px 0;
    border-radius: 8px;
}

.secondary { background: #3498db !important; }
.danger { background: #e74c3c !important; }
.closeBtn { background: #ccc !important; }
</style>
</head>

<body>

<div class="topbar">VA Classroom Dashboard</div>

<div class="container">

<div class="sidebar">
    <h3>Trainer View</h3>

    <button onclick="switchTrainer('Au')">Au</button>
    <button onclick="switchTrainer('Chanie')">Chanie</button>
    <button onclick="switchTrainer('Leo')">Leo</button>

    <hr>

    <div id="occupancy">0/10 seats</div>

    <h4>Search VA</h4>
    <input type="text" id="searchBox" onkeydown="handleSearchKey(event)">
</div>

<div class="main">

<div class="card">
    <h3>Assign VA</h3>

    <input id="vaName" placeholder="VA Name">
    <input id="agency" placeholder="Agency">

    <select id="trainerSelect">
        <option value="">Select Trainer</option>
        <option>Au</option>
        <option>Chanie</option>
        <option>Leo</option>
    </select>

    <button onclick="assignVA()">Assign VA</button>
</div>

<div class="card">
    <h3 id="classTitle"></h3>
    <div class="grid" id="seatGrid"></div>
</div>

</div>
</div>

<!-- TOAST -->
<div id="toast" class="toast"></div>

<!-- MODAL -->
<div id="modalOverlay" class="modal-overlay hidden">
    <div class="modal-box">
        <h3 id="modalTitle"></h3>
        <p id="modalMessage"></p>
        <input id="modalInput" class="hidden">

        <div class="modal-actions">
            <button id="modalCancel">Cancel</button>
            <button id="modalOk">OK</button>
        </div>
    </div>
</div>

<!-- ACTION -->
<div id="actionOverlay" class="modal-overlay hidden">
    <div class="action-box">
        <div id="actionTitle"></div>

        <button class="secondary" onclick="editVA()">Edit VA</button>
        <button class="secondary" onclick="moveVA()">Move VA</button>
        <button class="danger" onclick="deleteVA()">Delete VA</button>
        <button class="closeBtn" onclick="closeAction()">Close</button>
    </div>
</div>

<script>

let trainers = JSON.parse(localStorage.getItem("va_classrooms")) || {
    Au: [],
    Chanie: [],
    Leo: []
};

let currentTrainer = "Au";
let selectedIndex = null;

/* SAVE */
function saveData() {
    localStorage.setItem("va_classrooms", JSON.stringify(trainers));
}

/* TOAST */
function showToast(msg) {
    const t = document.getElementById("toast");
    t.innerText = msg;
    t.classList.add("show");
    setTimeout(() => t.classList.remove("show"), 2000);
}

/* MODAL */
function showModal({ title, message, input = false }) {
    return new Promise(resolve => {
        const overlay = document.getElementById("modalOverlay");
        const titleEl = document.getElementById("modalTitle");
        const msgEl = document.getElementById("modalMessage");
        const inputEl = document.getElementById("modalInput");

        titleEl.innerText = title;
        msgEl.innerText = message;

        overlay.classList.remove("hidden");
        requestAnimationFrame(() => overlay.classList.add("show"));

        if (input) {
            inputEl.classList.remove("hidden");
            inputEl.value = "";
        } else {
            inputEl.classList.add("hidden");
        }

        document.getElementById("modalOk").onclick = () => {
            overlay.classList.remove("show");
            setTimeout(() => overlay.classList.add("hidden"), 250);
            resolve(input ? inputEl.value : true);
        };

        document.getElementById("modalCancel").onclick = () => {
            overlay.classList.remove("show");
            setTimeout(() => overlay.classList.add("hidden"), 250);
            resolve(false);
        };
    });
}

/* SWITCH */
function switchTrainer(t) {
    currentTrainer = t;
    render();
}

/* ASSIGN */
function assignVA() {
    let name = document.getElementById("vaName").value;
    let agency = document.getElementById("agency").value;
    let trainer = document.getElementById("trainerSelect").value;

    if (!name || !agency || !trainer) return;

    trainers[trainer].push({ name, agency });

    saveData();
    render();
    showToast("VA added");
}

/* SEARCH (FIXED BUT SAFE) */
function handleSearchKey(e) {
    if (e.key === "Enter") searchVA(document.getElementById("searchBox").value);
}

function searchVA(q) {
    q = q.toLowerCase().trim();
    if (!q) return;

    let foundTrainer = null;
    let foundIndex = null;

    for (let t in trainers) {
        trainers[t].forEach((v, i) => {
            let name = v.name.toLowerCase();
            let words = name.split(" ");

            let match =
                name.includes(q) ||
                words.some(w => w.startsWith(q));

            if (match && !foundTrainer) {
                foundTrainer = t;
                foundIndex = i;
            }
        });
    }

    if (!foundTrainer) return;

    currentTrainer = foundTrainer;
    render();

    setTimeout(() => {
        let seats = document.querySelectorAll(".seat");
        seats.forEach((s, i) => {
            if (i === foundIndex) {
                s.classList.add("highlight");
                s.scrollIntoView({ behavior: "smooth", block: "center" });
            }
        });
    }, 100);
}

/* RENDER */
function render() {
    let grid = document.getElementById("seatGrid");
    grid.innerHTML = "";

    let list = trainers[currentTrainer];
    let filled = 0;

    document.getElementById("classTitle").innerText = currentTrainer;

    for (let i = 0; i < 10; i++) {
        let seat = document.createElement("div");
        seat.className = "seat";

        let va = list[i];

        if (va) {
            seat.innerHTML = `<b>${va.name}</b><br>${va.agency}`;
            seat.onclick = () => openAction(i);
            filled++;
        } else {
            seat.innerHTML = "Empty";
        }

        grid.appendChild(seat);
    }

    document.getElementById("occupancy").innerText = filled + "/10 seats";
}

/* ACTION */
function openAction(i) {
    selectedIndex = i;
    document.getElementById("actionOverlay").classList.remove("hidden");
    requestAnimationFrame(() =>
        document.getElementById("actionOverlay").classList.add("show")
    );
    document.getElementById("actionTitle").innerText =
        trainers[currentTrainer][i].name;
}

function closeAction() {
    let el = document.getElementById("actionOverlay");
    el.classList.remove("show");
    setTimeout(() => el.classList.add("hidden"), 250);
}

/* DELETE */
function deleteVA() {
    trainers[currentTrainer].splice(selectedIndex, 1);
    saveData();
    closeAction();
    render();
    showToast("VA deleted");
}

/* EDIT */
async function editVA() {
    closeAction();

    let name = await showModal({ title: "Edit Name", message: "", input: true });
    if (!name) return;

    let agency = await showModal({ title: "Edit Agency", message: "", input: true });
    if (!agency) return;

    trainers[currentTrainer][selectedIndex] = { name, agency };

    saveData();
    render();
    showToast("VA updated");
}

/* MOVE */
async function moveVA() {
    closeAction();

    let t = await showModal({
        title: "Move VA",
        message: "Enter trainer (Au, Chanie, Leo)",
        input: true
    });

    if (!trainers[t]) return;

    let va = trainers[currentTrainer][selectedIndex];

    trainers[t].push(va);
    trainers[currentTrainer].splice(selectedIndex, 1);

    saveData();
    render();
    showToast("VA moved");
}

/* INIT */
render();

</script>

</body>
</html>
